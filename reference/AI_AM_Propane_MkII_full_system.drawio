  <diagram id="bom" name="Bill of materials">
    <mxGraphModel dx="900" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="bomtitle" value="&lt;b&gt;AI AM Propane Mk. II - bill of materials (2 tanks, 3 branches, 1 poofer)&lt;/b&gt;" style="text;html=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="720" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="bomlist" value="2x - 20 lb DOT propane cylinder, OPD valve, in-date recertification&lt;br&gt;2x - POL x 1/4 in MNPT cylinder adapter (Mr. Heater F273754 - verify exact model)&lt;br&gt;6x - 1/4 in NPT brass ball valve, gas-rated (Apollo 94A series or CSA equivalent)&lt;br&gt;5x - LP hose assembly, 3/8 in SAE 45 deg flare ends (Mr. Heater F273702 - verify lengths)&lt;br&gt;1x - 3/8 in SAE 45 deg flare branch tee (Anderson Metals; use cross for 3 tanks)&lt;br&gt;1x - Fisher 67CH high-pressure regulator, 30-60 psi spring, 1/4 in FNPT (first stage, set 60 psi)&lt;br&gt;1x - Fisher 67CH-743 regulator, 3-35 psi, 1/4 in FNPT (second stage, set 30 psi) - no internal relief, add external overpressure protection&lt;br&gt;1x - brass manifold block, 1/4 in FNPT, 3 outlets, with 1/4 MNPT x 3/8 flare adapters&lt;br&gt;3x - STC 2W160-3/8 solenoid valve, 12 VDC, normally closed, Viton seals, zero differential (order code 2W160-3/8-1-V-D)&lt;br&gt;1x - STC 2W160-1/2 solenoid valve, 12 VDC, normally closed, Viton seals (poofer dump, order code 2W160-1/2-1-V-D)&lt;br&gt;4x - 1/4 in NPT brass needle valve (3 branch bypasses + 1 poofer pilot) + stepper actuators (custom)&lt;br&gt;1x - 1/4 in NPT brass spring check valve, Viton seat (accumulator fill)&lt;br&gt;1x - accumulator: DOT-certified LP cylinder, in-date only (expired tanks fail inspection)&lt;br&gt;bulk - 3/8 in and 1/4 in OD soft copper tubing, SAE 45 deg flare nuts and tees (Anderson Metals)&lt;br&gt;3-4x - steel wool pinhole pilots (custom fabrication)&lt;br&gt;bulk - LP-rated thread sealant (yellow gas-rated PTFE tape or Rectorseal)&lt;br&gt;&lt;br&gt;&lt;i&gt;Open questions carried over from the sketch: 30 psi regulator location, pilot count per branch, air mixer detail&lt;/i&gt;" style="text;html=1;align=left;verticalAlign=top;spacing=4;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="760" height="560" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
